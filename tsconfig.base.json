{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "$component-a": ["packages/sdk/src/modules/ui/component-a/index"],
      "$component-a/*": ["packages/sdk/src/modules/ui/component-a/*"],
      "$component-b": ["packages/sdk/src/modules/ui/component-b/index"],
      "$component-b/*": ["packages/sdk/src/modules/ui/component-b/*"],
      "@sdk/*": ["packages/sdk/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
