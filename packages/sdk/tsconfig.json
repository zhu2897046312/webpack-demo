{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@sdk/*": ["./src/*"],
      "$component-a/*": ["./src/modules/ui/component-a/*"],
      "$component-b/*": ["./src/modules/ui/component-b/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
