{
  "name": "@monorepo/sdk",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./component-a": {
      "import": "./src/modules/ui/component-a/index.ts",
      "require": "./dist/modules/ui/component-a/index.js",
      "default": "./dist/modules/ui/component-a/index.js"
    },
    "./component-b": {
      "import": "./src/modules/ui/component-b/index.ts",
      "require": "./dist/modules/ui/component-b/index.js",
      "default": "./dist/modules/ui/component-b/index.js"
    }
  },
  "scripts": {
    "build": "babel src -d dist --extensions \".ts\" && tsc --emitDeclarationOnly",
    "build:rollup": "rollup -c",
    "dev": "echo \"SDK dev placeholder\"",
    "build:tsc": "tsc"
  },
  "devDependencies": {
    "rollup": "^4.28.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@babel/cli": "^7.26.0",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0"
  }
}